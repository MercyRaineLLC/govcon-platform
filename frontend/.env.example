VITE_API_URL=http://localhost:3001

# =============================================================
# Stripe Pricing Table (Landing page only)
# =============================================================
# IMPORTANT: Use TEST mode keys for development to avoid real charges.
# Find these at https://dashboard.stripe.com/test/pricing-tables
#
# To create a test pricing table:
# 1. Go to https://dashboard.stripe.com/test/pricing-tables
# 2. Click "Create pricing table"
# 3. Add the 3 test prices (Starter, Professional, Enterprise — already
#    created in your Stripe test account; see backend/.env STRIPE_PRICE_*)
# 4. Copy the prctbl_xxx ID and pk_test_xxx publishable key here
# =============================================================
VITE_STRIPE_PRICING_TABLE_ID=prctbl_REPLACE_WITH_TEST_TABLE_ID
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_TEST_PUBLISHABLE_KEY

# =============================================================
# Observability (Sentry frontend) — leave blank to disable
# =============================================================
VITE_SENTRY_DSN=
