# =============================================================
# MrGovCon Frontend — Production Environment Template
# Vite bakes these values at BUILD TIME (not runtime).
# After editing .env.prod, rebuild the frontend container:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build frontend
# =============================================================

# Backend API base URL (no trailing slash, no /api suffix)
VITE_API_URL=https://mrgovcon.co

# Stripe publishable key (safe to expose in browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe pricing table ID (from Stripe Dashboard → Pricing Tables)
VITE_STRIPE_PRICING_TABLE_ID=prctbl_...

# ----------------------------
# Beta Mode (Pricing Mask)
# ----------------------------
# Set true to hide all dollar amounts and replace Stripe checkout CTAs
# with a "Request Beta Access" link. Stripe products remain untouched.
# Flip to false and rebuild at General Availability.
VITE_BETA_PRICING_HIDDEN=true

# Target URL for the "Request Beta Access" CTA button.
# Can be a mailto:, Google Form, Tally, or in-app /beta-access page.
VITE_BETA_REQUEST_URL=https://mrgovcon.co/beta-access
