// =============================================================
// GovCon Advisory Intelligence Platform
// Prisma Schema - Multi-Tenant SaaS Data Model
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// TENANT LAYER
// =============================================================

model ConsultingFirm {
  id           String  @id @default(uuid())
  name         String
  contactEmail String  @unique
  isActive     Boolean @default(true)

  // Penalty configuration
  flatLateFee    Float? // Fixed dollar penalty for late submissions
  penaltyPercent Float? // Percentage of estimated value for late submissions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users              User[]
  clientCompanies    ClientCompany[]
  opportunities      Opportunity[]
  financialPenalties FinancialPenalty[]

  @@map("consulting_firms")
}

model User {
  id               String   @id @default(uuid())
  consultingFirmId String
  email            String   @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             UserRole @default(CONSULTANT)
  isActive         Boolean  @default(true)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  consultingFirm    ConsultingFirm     @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submissionRecords SubmissionRecord[]

  @@index([consultingFirmId])
  @@map("users")
}

enum UserRole {
  ADMIN
  CONSULTANT
}

// =============================================================
// CLIENT LAYER
// =============================================================

model ClientCompany {
  id               String   @id @default(uuid())
  consultingFirmId String
  name             String
  cage             String?
  uei              String?
  naicsCodes       String[] // Registered NAICS codes for this contractor
  sdvosb           Boolean  @default(false)
  wosb             Boolean  @default(false)
  hubzone          Boolean  @default(false)
  smallBusiness    Boolean  @default(true)
  isActive         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  consultingFirm     ConsultingFirm     @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submissionRecords  SubmissionRecord[]
  performanceStats   PerformanceStats?
  financialPenalties FinancialPenalty[]

  @@index([consultingFirmId])
  @@map("client_companies")
}

// =============================================================
// OPPORTUNITY LAYER
// =============================================================

model Opportunity {
  id               String @id @default(uuid())
  consultingFirmId String

  // SAM.gov fields
  samNoticeId      String?        @unique
  title            String
  agency           String
  subagency        String?
  office           String?
  naicsCode        String
  naicsDescription String?
  setAsideType     SetAsideType   @default(NONE)
  marketCategory   MarketCategory @default(SUPPLIES)

  // Financials
  estimatedValue    Float?
  estimatedValueMin Float?
  estimatedValueMax Float?

  // Dates
  postedDate       DateTime?
  responseDeadline DateTime
  archiveDate      DateTime?

  // Location
  placeOfPerformance String?

  // Source data
  sourceUrl   String?
  description String? @db.Text
  attachments Json?

  // Computed fields (updated by scoring engine)
  probabilityScore Float? @default(0)
  expectedValue    Float? @default(0)

  // Status
  status OpportunityStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  consultingFirm    ConsultingFirm     @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submissionRecords SubmissionRecord[]

  @@index([consultingFirmId])
  @@index([naicsCode])
  @@index([agency])
  @@index([responseDeadline])
  @@index([probabilityScore])
  @@map("opportunities")
}

enum SetAsideType {
  NONE
  SMALL_BUSINESS
  SDVOSB
  WOSB
  HUBZONE
  EightA
  TOTAL_SMALL_BUSINESS
}

enum MarketCategory {
  SERVICES
  SUPPLIES
  CONSTRUCTION
  IT
  RESEARCH
  MEDICAL
  LOGISTICS
  OTHER
}

enum OpportunityStatus {
  ACTIVE
  AWARDED
  CANCELLED
  ARCHIVED
}

// =============================================================
// SUBMISSION TRACKING
// =============================================================

model SubmissionRecord {
  id               String @id @default(uuid())
  consultingFirmId String
  clientCompanyId  String
  opportunityId    String
  submittedById    String

  submittedAt   DateTime
  wasOnTime     Boolean
  penaltyAmount Float    @default(0)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clientCompany    ClientCompany     @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  opportunity      Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  submittedBy      User              @relation(fields: [submittedById], references: [id])
  financialPenalty FinancialPenalty?

  @@index([clientCompanyId])
  @@index([opportunityId])
  @@index([consultingFirmId])
  @@map("submission_records")
}

// =============================================================
// FINANCIAL PENALTIES
// =============================================================

model FinancialPenalty {
  id                 String @id @default(uuid())
  consultingFirmId   String
  clientCompanyId    String
  submissionRecordId String @unique

  penaltyType      PenaltyType
  amount           Float
  calculationBasis String // Human-readable explanation
  isPaid           Boolean     @default(false)
  paidAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  consultingFirm   ConsultingFirm   @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  submissionRecord SubmissionRecord @relation(fields: [submissionRecordId], references: [id])

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@map("financial_penalties")
}

enum PenaltyType {
  FLAT_FEE
  PERCENTAGE
}

// =============================================================
// PERFORMANCE STATISTICS
// =============================================================

model PerformanceStats {
  id              String @id @default(uuid())
  clientCompanyId String @unique

  totalOpportunities Int   @default(0)
  totalSubmissions   Int   @default(0)
  submissionsOnTime  Int   @default(0)
  submissionsLate    Int   @default(0)
  completionRate     Float @default(0) // submissionsOnTime / totalSubmissions
  totalPenalties     Float @default(0)

  lastCalculatedAt DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@map("performance_stats")
}
