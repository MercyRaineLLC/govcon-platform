# =============================================================
# MrGovCon Platform — Production Environment Template
# Copy to .env.prod and fill in all required values.
# NEVER commit .env.prod or any file containing real secrets.
# =============================================================

# ----------------------------
# Core Application
# ----------------------------
NODE_ENV=production
PORT=3001

# Public-facing URL (no trailing slash)
APP_URL=https://mrgovcon.co
FRONTEND_URL=https://mrgovcon.co

# Root domain for white-label subdomain matching
PLATFORM_ROOT_DOMAIN=mrgovcon.co

# Allowed CORS origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=https://mrgovcon.co

# ----------------------------
# Authentication
# ----------------------------
# REQUIRED. Must be 32+ chars in production. Rotating this invalidates all sessions.
JWT_SECRET=CHANGE_ME_minimum_32_chars_random_string_here
JWT_EXPIRES_IN=8h

# ----------------------------
# Database
# ----------------------------
# Inside Docker Compose (postgres service): host=postgres
# From host machine (for prisma db push): host=localhost
DATABASE_URL=postgresql://govcon_user:govcon_pass@postgres:5432/govcon_platform

# ----------------------------
# Redis / BullMQ
# ----------------------------
REDIS_URL=redis://redis:6379

# ----------------------------
# Stripe (Live Mode)
# ----------------------------
# REQUIRED for billing. Get from Stripe Dashboard → Developers.
STRIPE_SECRET_KEY=sk_live_...

# REQUIRED. Raw body parsing depends on this for signature verification.
# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# ISO date when the current webhook secret was last rotated (YYYY-MM-DD).
# The stripeWebhookRotationReminderWorker emails PLATFORM_ADMIN_EMAIL at day 75 and 90.
STRIPE_WEBHOOK_SECRET_ROTATED_AT=2026-01-01

# Price IDs from Stripe Dashboard → Products (must match live mode)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Publishable key (also set in frontend .env.prod)
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ----------------------------
# SMTP (Transactional Email)
# ----------------------------
# If unset, emails are logged but not delivered (dev mode).
# Recommended providers: Resend (resend.com), Postmark, AWS SES.
#   Resend: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_SECURE=true, SMTP_USER=resend, SMTP_PASS=re_...
#   Postmark: SMTP_HOST=smtp.postmarkapp.com, SMTP_PORT=587, SMTP_USER=<API token>, SMTP_PASS=<API token>
#   AWS SES: SMTP_HOST=email-smtp.<region>.amazonaws.com, SMTP_PORT=587, SMTP_USER=<SMTP user>, SMTP_PASS=<SMTP pass>
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_CHANGE_ME
SMTP_FROM=noreply@mrgovcon.co

# Platform operator email — receives Stripe rotation reminders, system alerts.
PLATFORM_ADMIN_EMAIL=johngladmon917@gmail.com

# ----------------------------
# AI / LLM Providers
# ----------------------------
# Primary: Claude (Anthropic). Fallback chain: OpenAI → DeepSeek → Insight Engine → LocalAI.
# At least one of ANTHROPIC_API_KEY or OPENAI_API_KEY must be set in production.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
INSIGHT_ENGINE_API_KEY=

# LocalAI / Ollama (on-prem fallback). Set if you have an Ollama sidecar.
LOCALAI_BASE_URL=http://govcon_ollama:11434
LOCALAI_MODEL=mistral

# Default provider if firm has not configured one: claude | openai | deepseek | localai
DEFAULT_LLM_PROVIDER=claude

# ----------------------------
# Google Cloud / BigQuery
# ----------------------------
# Project ID for BigQuery analytics (govcon_analytics dataset).
GCP_PROJECT_ID=gov-con-491005

# BigQuery dataset name (default: govcon_analytics)
BQ_DATASET=govcon_analytics

# Path inside the Docker container to the service-account JSON key.
# Mounted read-only via docker-compose.prod.yml: ./adc.json:/app/adc.json:ro
GOOGLE_APPLICATION_CREDENTIALS=/app/adc.json

# ----------------------------
# SAM.gov / USAspending
# ----------------------------
# Firm-level API keys override this via ConsultingFirm.samApiKey in DB.
SAM_API_KEY=
SAM_BASE_URL=https://api.sam.gov/opportunities/v2/search
USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2

# ----------------------------
# Twilio (SMS Notifications)
# ----------------------------
# Optional. Leave empty to disable SMS; deadline + scoring workers will skip SMS gracefully.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ----------------------------
# Rate Limiting
# ----------------------------
RATE_LIMIT_MAX=500
RATE_LIMIT_WINDOW_MS=900000

# ----------------------------
# Uploads / File Handling
# ----------------------------
# Max file upload size in MB (default: 10)
MAX_UPLOAD_MB=10

# ----------------------------
# Platform Feature Limits
# ----------------------------
# Max beta slots for Founders Lifetime tier (enforced at signup + billing)
MAX_BETA_SLOTS=10

# Per-firm portfolio scoring cap per run (default: 200)
PORTFOLIO_SCORING_CAP=200

# ----------------------------
# Logging
# ----------------------------
LOG_LEVEL=info

# ----------------------------
# State Procurement Portal Credentials
# ----------------------------
# Used by stateProcurementScraper.ts. Leave empty if not using state/municipal feature.
PORTAL_CA_USER=
PORTAL_CA_PASS=
PORTAL_FL_USER=
PORTAL_FL_PASS=
PORTAL_MD_USER=
PORTAL_MD_PASS=
PORTAL_PA_USER=
PORTAL_PA_PASS=
