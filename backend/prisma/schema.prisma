  consultingFirmId    String
  title               String
  primeContractor     String
  primeContractorUei  String?
  naicsCode           String?
  agency              String?
  estimatedValue      Decimal?  @db.Decimal(18, 2)
  responseDeadline    DateTime?
  description         String?
  contactEmail        String?
