  responseDeadline   DateTime?
  description        String?
  solicitationNumber String?
  contactEmail       String?
  sourceUrl          String?
  probabilityScore   Float?
  isScored           Boolean       @default(false)
  status             String        @default("ACTIVE")
  postedAt           DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)

  @@index([consultingFirmId])
  @@index([state])
  @@index([contractLevel])
  @@map("state_municipal_opportunities")
