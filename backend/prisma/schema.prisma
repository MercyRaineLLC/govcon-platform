//////////////////////////////////////////////////////////////
// DELIVERABLE COMMENTS — Threaded discussion on ClientDocument
//////////////////////////////////////////////////////////////

enum CommentAuthorType {
  CONSULTANT
  CLIENT
}

model DeliverableComment {
  id             String            @id @default(cuid())
  deliverableId  String
  authorType     CommentAuthorType
  authorId       String
  authorName     String
  body           String
  parentId       String?
  isResolved     Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  deliverable ClientDocument       @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  parent      DeliverableComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     DeliverableComment[] @relation("CommentReplies")

  @@index([deliverableId])
  @@index([parentId])
  @@map("deliverable_comments")
}

//////////////////////////////////////////////////////////////
// HISTORICAL MODEL BACKTEST (admin-only, not tenant-scoped)
//////////////////////////////////////////////////////////////

model BacktestRun {
  id               String    @id @default(uuid())
  consultingFirmId String    // audit only — who ran it
  triggeredBy      String?   // userId who initiated
  status           String    // 'RUNNING' | 'COMPLETE' | 'FAILED'
  sampleSize       Int
  yearsBack        Int
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  errorMessage     String?

  // Aggregate metrics (set on completion)
  predictionCount  Int?
  brierScore       Float?    // 0 = perfect, 0.25 = random, lower better
  meanProbability  Float?    // average predicted probability across winners
  calibrationBins  Json?     // [{ binMin, binMax, count, meanPred, observedRate }]
  factorMeans      Json?     // mean value per ProbabilityFeatures key

  predictions BacktestPrediction[]

  @@map("backtest_runs")
}

model MarketWatchlistEntry {
  id               String   @id @default(uuid())
  consultingFirmId String
  // Either a NAICS code or an agency name. Exactly one must be set.
  naicsCode        String?
  agency           String?
  // Optional: last digest delivery so worker doesn't double-send.
  lastDigestAt     DateTime?
  createdAt        DateTime @default(now())
  createdBy        String?

  @@unique([consultingFirmId, naicsCode, agency])
  @@index([consultingFirmId])
  @@map("market_watchlist_entries")
}

model BacktestPrediction {
  id          String      @id @default(uuid())
  runId       String
  run         BacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  // The contract (from USAspending)
  contractId    String   // generated_internal_id
  agency        String
  naicsCode     String
  awardAmount   Float
  awardDate     DateTime
  recipientName String
  recipientUei  String?

  // Synthetic client built from winner certifications
  syntheticClientNaics String[]
  syntheticSdvosb      Boolean
  syntheticWosb        Boolean
  syntheticHubzone     Boolean
  syntheticSmallBiz    Boolean

  // Prediction output
  predictedProbability Float
  rawScore             Float
  features             Json    // ProbabilityFeatures snapshot
  observedOutcome      Float   @default(1.0)  // 1.0 = winner

  createdAt DateTime @default(now())

  @@index([runId])
  @@map("backtest_predictions")
}

// ---------------------------------------------------------------
// Beta Access Waitlist
// Captures unauthenticated signups from the public /beta-access page.
// No tenant scope (firms don't exist yet at signup time).
// ---------------------------------------------------------------
model BetaAccessRequest {
  id            String   @id @default(uuid())
  email         String
  firmName      String?
  contactName   String?
  naicsFocus    String?  // primary NAICS the firm bids in (e.g. "541512")
  source        String?  // attribution: "landing", "billing", "referral", etc.
  notes         String?  // free-form text from the signup form
  ipAddress     String?  // for rate-limit dedup
  userAgent     String?

  // Lifecycle
  status        String   @default("PENDING") // PENDING | CONTACTED | INVITED | DECLINED
  contactedAt   DateTime?
  invitedAt     DateTime?
  invitedFirmId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@map("beta_access_requests")
}

// ---------------------------------------------------------------
// Beta Feedback — NPS-light + free-text from authenticated firm admins.
// Tenant-scoped via consultingFirmId for isolation.
// ---------------------------------------------------------------
model BetaFeedback {
  id                String   @id @default(uuid())
  consultingFirmId  String
  consultingFirm    ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submittedByUserId String
  npsScore          Int      // 0-10
  killFeature       String?  // "If you could remove one feature, what would it be?"
  addFeature        String?  // "If you could add one feature, what would it be?"
  freeText          String?

  createdAt DateTime @default(now())

  @@index([consultingFirmId, createdAt])
  @@map("beta_feedback")
}
