generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// TENANT LAYER
// =============================================================

model ConsultingFirm {
  id             String    @id @default(uuid())
  name           String
  contactEmail   String    @unique
  isActive       Boolean   @default(true)
  lastIngestedAt DateTime?
  flatLateFee    Decimal?  @db.Decimal(12, 2)
  penaltyPercent Decimal?  @db.Decimal(5, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  users                User[]
  clientCompanies      ClientCompany[]
  opportunities        Opportunity[]
  financialPenalties   FinancialPenalty[]
  ingestionJobs        IngestionJob[]
  submissionRecords    SubmissionRecord[]
  bidDecisions         BidDecision[]
  documentRequirements DocumentRequirement[]

  @@map("consulting_firms")
}

model User {
  id               String    @id @default(uuid())
  consultingFirmId String
  email            String    @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             String
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  consultingFirm    ConsultingFirm     @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submissionRecords SubmissionRecord[]

  @@index([consultingFirmId])
  @@map("users")
}

// =============================================================
// CLIENT LAYER
// =============================================================

model ClientCompany {
  id                String   @id @default(uuid())
  consultingFirmId  String
  name              String
  cage              String?
  uei               String?
  naicsCodes        String[]
  preferredPscCodes String[]
  sdvosb            Boolean  @default(false)
  wosb              Boolean  @default(false)
  hubzone           Boolean  @default(false)
  smallBusiness     Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  consultingFirm       ConsultingFirm        @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  performanceStats     PerformanceStats?
  submissionRecords    SubmissionRecord[]
  financialPenalties   FinancialPenalty[]
  bidDecisions         BidDecision[]
  documentRequirements DocumentRequirement[]
  clientPortalUsers    ClientPortalUser[]
  complianceRewards    ComplianceReward[]

  @@index([consultingFirmId])
  @@map("client_companies")
}

// =============================================================
// OPPORTUNITY LAYER
// =============================================================

model Opportunity {
  id               String    @id @default(uuid())
  consultingFirmId String
  samNoticeId      String?
  title            String
  agency           String
  subagency        String?
  office           String?
  naicsCode        String
  naicsDescription String?
  setAsideType     String    @default("NONE")
  marketCategory   String    @default("SERVICES")
  estimatedValue   Float?
  estimatedValueMin Float?
  estimatedValueMax Float?
  postedDate       DateTime?
  responseDeadline DateTime
  archiveDate      DateTime?
  placeOfPerformance String?
  sourceUrl        String?
  description      String?
  probabilityScore Float     @default(0)
  expectedValue    Float     @default(0)
  isScored         Boolean   @default(false)
  status           String    @default("ACTIVE")
  scoreBreakdown   Json?

  // Tier 2: USAspending enrichment
  isEnriched              Boolean  @default(false)
  historicalWinner        String?
  historicalAvgAward      Float?
  historicalAwardCount    Int?
  competitionCount        Int?
  incumbentProbability    Float?
  agencySmallBizRate      Float?
  agencySdvosbRate        Float?
  recompeteFlag           Boolean  @default(false)

  // Tier 3: Document intelligence
  documentIntelScore      Float?
  scopeAlignmentScore     Float?
  technicalComplexScore   Float?
  incumbentSignalDetected Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultingFirm       ConsultingFirm        @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  documents            OpportunityDocument[]
  amendments           Amendment[]
  awardHistory         AwardHistory[]
  submissionRecords    SubmissionRecord[]
  bidDecisions         BidDecision[]
  documentRequirements DocumentRequirement[]

  @@unique([consultingFirmId, samNoticeId])
  @@index([consultingFirmId])
  @@index([naicsCode])
  @@index([agency])
  @@index([responseDeadline])
  @@index([probabilityScore])
  @@map("opportunities")
}

// =============================================================
// AMENDMENTS
// =============================================================

model Amendment {
  id                   String    @id @default(uuid())
  opportunityId        String
  amendmentNo          String?
  amendmentNumber      String?
  title                String?
  description          String?
  issuedDate           DateTime?
  postedDate           DateTime?
  plainLanguageSummary String?
  interpretedAt        DateTime?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@map("amendments")
}

// =============================================================
// AWARD HISTORY (USAspending enrichment)
// =============================================================

model AwardHistory {
  id                String   @id @default(cuid())
  opportunityId     String
  awardingAgency    String   @default("")
  recipientName     String   @default("")
  recipientUei      String?
  awardAmount       Float    @default(0)
  awardDate         DateTime @default(now())
  baseAndAllOptions Float?
  naics             String?
  psc               String?
  awardType         String?
  contractNumber    String?
  createdAt         DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([recipientName])
  @@index([naics])
  @@map("award_history")
}

// =============================================================
// OPPORTUNITY DOCUMENTS
// =============================================================

model OpportunityDocument {
  id            String   @id @default(cuid())
  opportunityId String
  fileName      String
  fileType      String   @default("")
  fileSize      Int      @default(0)
  storageKey    String   @default("")
  fileUrl       String?
  isAmendment   Boolean  @default(false)
  uploadedAt    DateTime @default(now())

  // Claude analysis
  analysisStatus   String   @default("PENDING")
  analysisError    String?
  scopeKeywords    String[]
  complexityScore  Float?
  alignmentScore   Float?
  incumbentSignals String[]
  rawAnalysis      Json?
  analyzedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@map("opportunity_documents")
}

// =============================================================
// INGESTION JOB TRACKING
// =============================================================

model IngestionJob {
  id               String    @id @default(cuid())
  consultingFirmId String
  type             String
  status           String    @default("PENDING")

  opportunitiesFound Int?
  opportunitiesNew   Int?
  enrichedCount      Int?
  scoringJobsQueued  Int?
  errors             Int?
  errorDetail        String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)

  @@index([consultingFirmId])
  @@index([status])
  @@map("ingestion_jobs")
}

// =============================================================
// SUBMISSION RECORDS
// =============================================================

model SubmissionRecord {
  id               String    @id @default(uuid())
  consultingFirmId String
  clientCompanyId  String
  opportunityId    String
  submittedById    String?
  submittedAt      DateTime?
  wasOnTime        Boolean   @default(true)
  penaltyAmount    Float     @default(0)
  notes            String?
  status           String?
  createdAt        DateTime  @default(now())

  consultingFirm  ConsultingFirm   @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany   ClientCompany    @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  opportunity     Opportunity      @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  submittedBy     User?            @relation(fields: [submittedById], references: [id])
  financialPenalty FinancialPenalty?

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@map("submission_records")
}

// =============================================================
// FINANCIAL PENALTIES
// =============================================================

model FinancialPenalty {
  id                 String    @id @default(uuid())
  consultingFirmId   String
  clientCompanyId    String
  submissionRecordId String?   @unique
  amount             Decimal   @db.Decimal(12, 2)
  reason             String
  isPaid             Boolean   @default(false)
  paidAt             DateTime?
  appliedAt          DateTime  @default(now())
  createdAt          DateTime  @default(now())

  consultingFirm   ConsultingFirm    @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany    ClientCompany     @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  submissionRecord SubmissionRecord? @relation(fields: [submissionRecordId], references: [id])

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@map("financial_penalties")
}

// =============================================================
// PERFORMANCE STATISTICS
// =============================================================

model PerformanceStats {
  id                 String   @id @default(uuid())
  clientCompanyId    String   @unique
  totalOpportunities Int      @default(0)
  totalSubmitted     Int      @default(0)
  totalSubmissions   Int      @default(0)
  totalWon           Int      @default(0)
  totalLost          Int      @default(0)
  submissionsOnTime  Int      @default(0)
  submissionsLate    Int      @default(0)
  completionRate     Float    @default(0)
  totalPenalties     Float    @default(0)
  lastCalculatedAt   DateTime?
  updatedAt          DateTime @updatedAt

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@map("performance_stats")
}

// =============================================================
// BID DECISIONS
// =============================================================

model BidDecision {
  id                  String   @id @default(uuid())
  consultingFirmId    String
  clientCompanyId     String
  opportunityId       String
  decision            String   @default("PENDING")
  recommendation      String?
  rationale           String?
  winProbability      Float?
  expectedRevenue     Float?
  proposalCostEstimate Float?
  expectedValue       Float?
  netExpectedValue    Float?
  roiRatio            Float?
  complianceStatus    String?
  riskScore           Int?
  explanationJson     Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany  ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  opportunity    Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, clientCompanyId])
  @@index([consultingFirmId])
  @@map("bid_decisions")
}

// =============================================================
// CLIENT PORTAL USERS
// =============================================================

model ClientPortalUser {
  id              String    @id @default(cuid())
  clientCompanyId String
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@index([clientCompanyId])
  @@map("client_portal_users")
}

// =============================================================
// DOCUMENT REQUIREMENTS
// =============================================================

model DocumentRequirement {
  id               String    @id @default(cuid())
  consultingFirmId String
  clientCompanyId  String
  opportunityId    String?
  title            String
  description      String?
  dueDate          DateTime
  isPenaltyEnabled Boolean   @default(true)
  penaltyAmount    Decimal?  @db.Decimal(12, 2)
  penaltyPercent   Decimal?  @db.Decimal(5, 2)
  status           String    @default("PENDING")
  submittedAt      DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany  ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@index([opportunityId])
  @@map("document_requirements")
}

// =============================================================
// COMPLIANCE REWARDS
// =============================================================

model ComplianceReward {
  id              String    @id @default(cuid())
  clientCompanyId String
  rewardType      String
  description     String
  value           Decimal?  @db.Decimal(12, 2)
  percentDiscount Decimal?  @db.Decimal(5, 2)
  isRedeemed      Boolean   @default(false)
  redeemedAt      DateTime?
  expiresAt       DateTime?
  triggerReason   String
  createdAt       DateTime  @default(now())

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@index([clientCompanyId])
  @@map("compliance_rewards")
}