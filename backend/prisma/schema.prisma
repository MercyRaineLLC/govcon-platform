  @@index([naicsCode])
  @@index([status])
  @@map("subcontract_opportunities")
}

//////////////////////////////////////////////////////////////
// COMPETITIVE INTELLIGENCE CACHE
//////////////////////////////////////////////////////////////

model NaicsCompetitiveDensity {
  id              String   @id @default(uuid())
  naicsCode       String   @unique
  avgBidders      Float    @default(5.0)
  medianBidders   Float?
  avgAwardValue   Float?
  smallBizRate    Float    @default(0.5)
  sdvosbRate      Float    @default(0.1)
  totalContracts  Int      @default(0)
  lastRefreshedAt DateTime @default(now())

  @@map("naics_competitive_density")
}

model AgencyAwardProfile {
  id              String   @id @default(uuid())
  agencyName      String   @unique
  avgAwardValue   Float?
  smallBizRate    Float    @default(0.5)
  sdvosbRate      Float    @default(0.1)
  womenOwnedRate  Float    @default(0.1)
  hubzoneRate     Float    @default(0.05)
  totalAwards     Int      @default(0)
  typicalNaics    String[] @default([])
  lastRefreshedAt DateTime @default(now())

  @@map("agency_award_profiles")
