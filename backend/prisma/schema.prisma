generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////////

enum OpportunityStatus {
  ACTIVE
  ARCHIVED
  EXPIRED
  AWARDED
}

enum BidDecisionStatus {
  PENDING
  GO
  NO_GO
}

enum ComplianceStatus {
  PENDING
  APPROVED
  BLOCKED
  REJECTED
}

enum PenaltyType {
  LATE_SUBMISSION
  DOCUMENT_ERROR
  NON_COMPLIANT_BID
  WITHDRAWAL
  OTHER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum IngestionJobType {
  INGEST
  ENRICH
  ANALYZE_DOCUMENT
}

enum IngestionJobStatus {
  PENDING
  RUNNING
  COMPLETE
  FAILED
  PARTIAL
}

enum DocumentAnalysisStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  FAILED
  SKIPPED
}

enum DocumentRequirementStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum MatrixRequirementStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PENDING_REVIEW
  BLOCKED
}

enum ComplianceLogEntityType {
  SUBMISSION
  BID_DECISION
  OPPORTUNITY
  CLIENT_COMPANY
  DOCUMENT_REQUIREMENT
  OTHER
}

//////////////////////////////////////////////////////////////
// TENANT LAYER
//////////////////////////////////////////////////////////////

model ConsultingFirm {
  id             String    @id @default(uuid())
  name           String
  contactEmail   String    @unique
  isActive       Boolean   @default(true)
  lastIngestedAt DateTime?
  flatLateFee    Decimal?  @db.Decimal(14, 2)
  penaltyPercent Decimal?  @db.Decimal(5, 2)
  samApiKey           String?
  anthropicApiKey     String?
  llmProvider         String   @default("claude")
  openaiApiKey        String?
  insightEngineApiKey String?
  localaiBaseUrl      String?
  localaiModel        String?
  deepseekApiKey      String?
  purchasedAddons     String[] @default([])
  isVeteranOwned      Boolean  @default(false)
  proposalTokens      Int      @default(0)
  lastTokenRefreshAt  DateTime?
  brandingLogoUrl     String?
  brandingPrimaryColor String? @default("#fbbf24")
  brandingSecondaryColor String? @default("#f59e0b")
  brandingDisplayName String?
  brandingTagline     String?
  brandingFaviconUrl  String?
  stripeCustomerId    String?  @unique
  stripeSubscriptionId String? @unique
  lifetimeAccessAt    DateTime?
  subdomain           String?  @unique
  customDomain        String?  @unique
  customDomainVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  users                User[]
  clientCompanies      ClientCompany[]
  opportunities        Opportunity[]
  financialPenalties   FinancialPenalty[]
  ingestionJobs        IngestionJob[]
  submissionRecords    SubmissionRecord[]
  bidDecisions         BidDecision[]
  documentRequirements DocumentRequirement[]
  documentTemplates    DocumentTemplate[]
  complianceLogs       ComplianceLog[]
  clientDocuments      ClientDocument[]
  submittedTemplates   SharedTemplate[]
  complianceMatrices   ComplianceMatrix[]
  portalUploads        ClientPortalUpload[]
  apiUsageLogs             ApiUsageLog[]
  subscription             Subscription?
  invoices                 Invoice[]
  stateMunicipalOpps       StateMunicipalOpportunity[]
  subcontractOpportunities SubcontractOpportunity[]

  @@map("consulting_firms")
}

model User {
  id                String    @id @default(uuid())
  consultingFirmId  String
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              String
  isActive          Boolean   @default(true)
  isEmailVerified   Boolean   @default(false)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  consultingFirm    ConsultingFirm     @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submissionRecords SubmissionRecord[]
  createdTemplates  DocumentTemplate[] @relation("TemplateCreator")

  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  agreements               UserAgreement[]

  @@index([consultingFirmId])
  @@map("users")
}

//////////////////////////////////////////////////////////////
// PASSWORD RESET
//////////////////////////////////////////////////////////////

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

//////////////////////////////////////////////////////////////
// BID DECISION AUDIT TRAIL
//////////////////////////////////////////////////////////////

model BidDecisionHistory {
  id                String   @id @default(uuid())
  consultingFirmId  String
  opportunityId     String
  clientCompanyId   String
  recommendation    String
  winProbability    Float?
  fitScore          Float?
  marketScore       Float?
  expectedValue     Float?
  roiRatio          Float?
  changedBy         String?
  changeReason      String?
  snapshotJson      Json?
  createdAt         DateTime @default(now())

  @@index([consultingFirmId])
  @@index([opportunityId])
  @@index([clientCompanyId])
  @@map("bid_decision_history")
}

//////////////////////////////////////////////////////////////
// NAICS NORMALIZATION
// (Kept for future normalized lookups / enrichment queries)
//////////////////////////////////////////////////////////////

model NaicsCode {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?
  sector      String?

  opportunities Opportunity[]
  clientLinks   ClientNaics[]

  @@map("naics_codes")
}

model ClientNaics {
  id              String @id @default(uuid())
  clientCompanyId String
  naicsCodeId     String

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  naicsCode     NaicsCode     @relation(fields: [naicsCodeId], references: [id], onDelete: Cascade)

  @@unique([clientCompanyId, naicsCodeId])
  @@map("client_naics")
}

//////////////////////////////////////////////////////////////
// CLIENT LAYER
//////////////////////////////////////////////////////////////

model ClientCompany {
  id               String   @id @default(uuid())
  consultingFirmId String
  name             String
  cage             String?
  uei              String?
  naicsCodes       String[] @default([])
  sdvosb           Boolean  @default(false)
  wosb             Boolean  @default(false)
  hubzone          Boolean  @default(false)
  smallBusiness    Boolean  @default(true)
  isActive         Boolean  @default(true)

  // Extended profile (auto-populated from SAM.gov Entity API)
  ein              String?   // Employer Identification Number / Tax ID
  phone            String?
  website          String?
  streetAddress    String?
  city             String?
  state            String?
  zipCode          String?
  samRegStatus     String?   // "Active" | "Inactive"
  samRegExpiry     DateTime?

  // Contract vehicles this client holds (e.g. ["OASIS+", "SEWP V"])
  contractVehicles String[] @default([])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  consultingFirm       ConsultingFirm        @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  performanceStats     PerformanceStats?
  submissionRecords    SubmissionRecord[]
  financialPenalties   FinancialPenalty[]
  bidDecisions         BidDecision[]
  naicsLinks           ClientNaics[]
  documentRequirements DocumentRequirement[]
  clientPortalUsers    ClientPortalUser[]
  complianceRewards    ComplianceReward[]
  clientDocuments      ClientDocument[]
  opportunityDeclines  ClientOpportunityDecline[]
  portalUploads        ClientPortalUpload[]

  @@index([consultingFirmId])
  @@map("client_companies")
}

//////////////////////////////////////////////////////////////
// OPPORTUNITY LAYER
//////////////////////////////////////////////////////////////

model Opportunity {
  id               String  @id @default(uuid())
  consultingFirmId String
  samNoticeId      String?
  title            String
  agency           String
  subagency        String?
  office           String?

  // Denormalized NAICS code for fast access (set by SAM ingestion)
  naicsCode   String  @default("")
  // Normalized relation (optional, for enrichment lookups)
  naicsCodeId String?
  naicsCodeRef NaicsCode? @relation(fields: [naicsCodeId], references: [id])

  setAsideType   String @default("NONE")
  marketCategory String @default("SERVICES")

  estimatedValue    Decimal? @db.Decimal(14, 2)
  estimatedValueMin Decimal? @db.Decimal(14, 2)
  estimatedValueMax Decimal? @db.Decimal(14, 2)

  postedDate         DateTime?
  responseDeadline   DateTime
  archiveDate        DateTime?
  placeOfPerformance String?
  sourceUrl          String?
  description        String?
  scoreBreakdown     Json?

  probabilityScore Float             @default(0)
  expectedValue    Decimal?          @db.Decimal(14, 2)
  isScored         Boolean           @default(false)
  status           OpportunityStatus @default(ACTIVE)

  // USAspending enrichment
  isEnriched           Boolean  @default(false)
  historicalWinner     String?
  historicalAvgAward   Decimal? @db.Decimal(14, 2)
  historicalAwardCount Int?
  competitionCount     Int?
  incumbentProbability Float?
  agencySmallBizRate   Float?
  agencySdvosbRate     Float?
  recompeteFlag        Boolean  @default(false)

  // Notice type from SAM.gov (e.g. "Presolicitation", "Solicitation", "Sources Sought", "Sole Source")
  noticeType              String?

  // FPDS competition data (from USAspending offersReceived field)
  offersReceived          Int?
  extentCompeted          String?

  // Document intelligence
  documentIntelScore      Float?
  scopeAlignmentScore     Float?
  technicalComplexScore   Float?
  incumbentSignalDetected Boolean @default(false)

  // Contract vehicle tagging (detected from title/description during ingest)
  contractVehicle   String?  // e.g. "OASIS+", "SEWP V", "GSA MAS"
  vehicleType       String?  // "GWAC" | "IDIQ" | "BPA" | "MAS" | "BOA"
  vehicleConfidence Float?   // 0-1 detection confidence

  // Advanced scoring signals (computed by scoring worker + nightly recalibration)
  deadlineUrgencyScore Float?   // 0-1: quality of proposal prep window (sweet spot = 2-6 weeks)
  densityRatio         Float?   // bidders vs NAICS norm (< 1.0 = below-average competition)
  agencyHistoryScore   Float?   // 0-1: agency set-aside affinity for this client type

  // Proposal assistant — persisted so navigating away doesn't lose work
  savedProposalOutline  Json?   // The AI-generated outline object
  savedProposalAnswers  Json?   // User's Q&A answers { questionId → answer }
  savedProposalStep     String? // 'outlined' | 'answering' etc.
  savedProposalDraft    Json?   // Generated draft sections (cached to avoid re-billing)
  savedProposalPdfKey   String? // Filename in /app/uploads for the cached PDF
  savedProposalDraftAt  DateTime? // When the cached draft was generated

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultingFirm       ConsultingFirm        @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  documents            OpportunityDocument[]
  amendments           Amendment[]
  awardHistory         AwardHistory[]
  submissionRecords    SubmissionRecord[]
  bidDecisions         BidDecision[]
  documentRequirements DocumentRequirement[]
  complianceMatrix     ComplianceMatrix?
  clientDeclines       ClientOpportunityDecline[]

  @@unique([consultingFirmId, samNoticeId])
  @@index([consultingFirmId])
  @@index([naicsCodeId])
  @@index([agency])
  @@index([responseDeadline])
  @@index([probabilityScore])
  @@map("opportunities")
}

//////////////////////////////////////////////////////////////
// AMENDMENTS
//////////////////////////////////////////////////////////////

model Amendment {
  id                   String    @id @default(uuid())
  opportunityId        String
  amendmentNo          String?
  amendmentNumber      String?
  title                String?
  description          String?
  issuedDate           DateTime?
  postedDate           DateTime?
  plainLanguageSummary String?
  interpretedAt        DateTime?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@map("amendments")
}

//////////////////////////////////////////////////////////////
// AWARD HISTORY
//////////////////////////////////////////////////////////////

model AwardHistory {
  id               String   @id @default(cuid())
  opportunityId    String
  awardingAgency   String   @default("")
  recipientName    String   @default("")
  recipientUei     String?
  awardAmount      Decimal  @db.Decimal(14, 2)
  awardDate        DateTime @default(now())
  baseAndAllOptions Decimal? @db.Decimal(14, 2)
  naics            String?
  psc              String?
  awardType        String?
  contractNumber   String?
  createdAt        DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([recipientName])
  @@map("award_history")
}

//////////////////////////////////////////////////////////////
// OPPORTUNITY DOCUMENTS
//////////////////////////////////////////////////////////////

model OpportunityDocument {
  id            String   @id @default(cuid())
  opportunityId String
  fileName      String
  fileType      String
  fileSize      Int
  storageKey    String
  fileUrl       String?
  isAmendment   Boolean  @default(false)
  uploadedAt    DateTime @default(now())

  analysisStatus   DocumentAnalysisStatus @default(PENDING)
  analysisError    String?
  scopeKeywords    String[]
  complexityScore  Float?
  alignmentScore   Float?
  incumbentSignals String[]
  rawAnalysis      Json?
  analyzedAt       DateTime?

  // Requirement extraction tracking
  extractionStatus              String    @default("PENDING")  // PENDING, EXTRACTING, EXTRACTED, FAILED
  extractedRequirementCount     Int       @default(0)
  extractionConfidence          Float?    // 0-1: overall confidence in extraction
  extractionError               String?
  extractedAt                   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  extractedRequirements MatrixRequirement[] @relation("SourceDocument")

  @@index([opportunityId])
  @@index([extractionStatus])
  @@map("opportunity_documents")
}

//////////////////////////////////////////////////////////////
// INGESTION JOBS
//////////////////////////////////////////////////////////////

model IngestionJob {
  id               String                @id @default(cuid())
  consultingFirmId String
  type             IngestionJobType
  status           IngestionJobStatus    @default(PENDING)

  opportunitiesFound Int?
  opportunitiesNew   Int?
  enrichedCount      Int?
  scoringJobsQueued  Int?
  errors             Int?
  errorDetail        String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)

  @@index([consultingFirmId])
  @@index([status])
  @@map("ingestion_jobs")
}

//////////////////////////////////////////////////////////////
// SUBMISSIONS
//////////////////////////////////////////////////////////////

model SubmissionRecord {
  id               String           @id @default(uuid())
  consultingFirmId String
  clientCompanyId  String
  opportunityId    String
  submittedById    String?
  submittedAt      DateTime?
  wasOnTime        Boolean          @default(true)
  penaltyAmount    Decimal          @default(0) @db.Decimal(14, 2)
  notes            String?
  status           ComplianceStatus @default(PENDING)
  createdAt        DateTime         @default(now())

  consultingFirm     ConsultingFirm     @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany      ClientCompany      @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  opportunity        Opportunity        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  submittedBy        User?              @relation(fields: [submittedById], references: [id])
  financialPenalties FinancialPenalty[]

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@map("submission_records")
}

//////////////////////////////////////////////////////////////
// FINANCIAL PENALTIES
//////////////////////////////////////////////////////////////

model FinancialPenalty {
  id                 String      @id @default(uuid())
  consultingFirmId   String
  clientCompanyId    String
  submissionRecordId String?
  amount             Decimal     @db.Decimal(14, 2)
  penaltyType        PenaltyType @default(OTHER)
  reason             String
  isPaid             Boolean     @default(false)
  paidAt             DateTime?
  appliedAt          DateTime    @default(now())
  createdAt          DateTime    @default(now())

  consultingFirm   ConsultingFirm    @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany    ClientCompany     @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  submissionRecord SubmissionRecord? @relation(fields: [submissionRecordId], references: [id])

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@map("financial_penalties")
}

//////////////////////////////////////////////////////////////
// PERFORMANCE STATS
//////////////////////////////////////////////////////////////

model PerformanceStats {
  id                 String    @id @default(uuid())
  clientCompanyId    String    @unique
  totalOpportunities Int       @default(0)
  totalSubmitted     Int       @default(0)
  totalWon           Int       @default(0)
  totalLost          Int       @default(0)
  submissionsOnTime  Int       @default(0)
  submissionsLate    Int       @default(0)
  completionRate     Float     @default(0)
  totalPenalties     Decimal   @default(0) @db.Decimal(14, 2)
  lastCalculatedAt   DateTime?
  updatedAt          DateTime  @updatedAt

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@map("performance_stats")
}

//////////////////////////////////////////////////////////////
// BID DECISIONS
//////////////////////////////////////////////////////////////

model BidDecision {
  id                   String            @id @default(uuid())
  consultingFirmId     String
  clientCompanyId      String
  opportunityId        String
  decision             BidDecisionStatus @default(PENDING)
  recommendation       String?
  rationale            String?
  winProbability       Float?
  expectedRevenue      Decimal?          @db.Decimal(14, 2)
  proposalCostEstimate Decimal?          @db.Decimal(14, 2)
  expectedValue        Decimal?          @db.Decimal(14, 2)
  netExpectedValue     Decimal?          @db.Decimal(14, 2)
  roiRatio             Float?
  complianceGate       String?           // 'ELIGIBLE' | 'CONDITIONAL' | 'INELIGIBLE'
  fitScore             Float?            // 0-100 client capability score
  marketScore          Float?            // 0-100 opportunity attractiveness score
  complianceStatus     ComplianceStatus  @default(PENDING)
  riskScore            Int?
  explanationJson      Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany  ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  opportunity    Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, clientCompanyId])
  @@index([consultingFirmId])
  @@map("bid_decisions")
}

// =============================================================
// CLIENT PORTAL USERS
// =============================================================

model ClientPortalUser {
  id              String    @id @default(cuid())
  clientCompanyId String
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  notifyDeliverables Boolean @default(true)
  notifyDeadlines    Boolean @default(true)
  notifyApprovals    Boolean @default(true)
  smsPhone           String?
  smsEnabled         Boolean @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@index([clientCompanyId])
  @@map("client_portal_users")
}

// =============================================================
// DOCUMENT REQUIREMENTS
// =============================================================

model DocumentRequirement {
  id               String    @id @default(cuid())
  consultingFirmId String
  clientCompanyId  String
  opportunityId    String?
  templateId       String?
  title            String
  description      String?
  dueDate          DateTime
  isPenaltyEnabled Boolean                   @default(true)
  penaltyAmount    Decimal?                  @db.Decimal(12, 2)
  penaltyPercent   Decimal?                  @db.Decimal(5, 2)
  status           DocumentRequirementStatus @default(PENDING)
  submittedAt      DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany  ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  template       DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@index([opportunityId])
  @@index([templateId])
  @@map("document_requirements")
}

// =============================================================
// DOCUMENT TEMPLATES
// =============================================================

model DocumentTemplate {
  id               String    @id @default(cuid())
  consultingFirmId String
  createdById      String?
  title            String
  description      String?
  category         String?
  fileName         String
  fileType         String
  fileSize         Int
  storageKey       String
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  consultingFirm        ConsultingFirm         @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  createdBy             User?                  @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  documentRequirements  DocumentRequirement[]

  @@index([consultingFirmId])
  @@index([createdById])
  @@map("document_templates")
}

// =============================================================
// COMPLIANCE REWARDS
// =============================================================

model ComplianceReward {
  id              String    @id @default(cuid())
  clientCompanyId String
  rewardType      String
  description     String
  value           Decimal?  @db.Decimal(12, 2)
  percentDiscount Decimal?  @db.Decimal(5, 2)
  isRedeemed      Boolean   @default(false)
  redeemedAt      DateTime?
  expiresAt       DateTime?
  triggerReason   String
  createdAt       DateTime  @default(now())

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@index([clientCompanyId])
  @@map("compliance_rewards")
}

//////////////////////////////////////////////////////////////
// COMPLIANCE AUDIT LOG
//////////////////////////////////////////////////////////////

model ComplianceLog {
  id               String                    @id @default(uuid())
  consultingFirmId String
  entityType       ComplianceLogEntityType
  entityId         String
  fromStatus       String?
  toStatus         String
  reason           String?
  triggeredBy      String?  // userId of the person who made the change
  createdAt        DateTime @default(now())

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([consultingFirmId])
  @@map("compliance_logs")
}



//////////////////////////////////////////////////////////////
// CLIENT COMPANY DOCUMENTS (branded uploads)
//////////////////////////////////////////////////////////////

enum ClientDocumentType {
  CAPABILITY_STATEMENT
  PAST_PERFORMANCE
  TECHNICAL_PROPOSAL
  MANAGEMENT_APPROACH
  PRICE_VOLUME
  SMALL_BUSINESS_PLAN
  TEAMING_AGREEMENT
  COVER_LETTER
  OTHER
}

enum SharedTemplateStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model ClientDocument {
  id               String             @id @default(cuid())
  consultingFirmId String
  clientCompanyId  String
  documentType     ClientDocumentType @default(OTHER)
  fileName         String
  fileType         String
  fileSize         Int                @default(0)
  storageKey       String
  fileUrl          String?
  title            String
  notes            String?
  isSharedAsTemplate Boolean          @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  consultingFirm ConsultingFirm  @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany  ClientCompany   @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  sharedTemplate SharedTemplate?
  comments       DeliverableComment[]

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@map("client_documents")
}

model SharedTemplate {
  id                   String               @id @default(cuid())
  sourceDocumentId     String               @unique
  submittedByFirmId    String
  documentType         ClientDocumentType
  title                String
  description          String?
  anonymizedStorageKey String
  status               SharedTemplateStatus @default(PENDING_REVIEW)
  reviewNotes          String?
  downloadCount        Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  sourceDocument  ClientDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  submittedByFirm ConsultingFirm @relation(fields: [submittedByFirmId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([documentType])
  @@map("shared_templates")
}

//////////////////////////////////////////////////////////////
// COMPLIANCE MATRIX (RFP Section L / M Extractor)
//////////////////////////////////////////////////////////////

model ComplianceMatrix {
  id               String    @id @default(cuid())
  opportunityId    String    @unique
  consultingFirmId String
  sourceText       String?   // snippet used for generation
  generatedAt      DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  bidGuidanceJson  Json?     // structured win-strategy output from Claude
  bidGuidanceAt    DateTime? // when bid guidance was last generated

  opportunity    Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  requirements   MatrixRequirement[]

  @@index([consultingFirmId])
  @@map("compliance_matrices")
}

model MatrixRequirement {
  id              String  @id @default(cuid())
  matrixId        String
  section         String
  sectionType     String                    @default("INSTRUCTION")
  requirementText String
  proposalSection String?
  status          MatrixRequirementStatus   @default(NOT_STARTED)
  notes           String?
  isMandatory     Boolean @default(true)
  farReference    String?
  sortOrder       Int     @default(0)

  // Source document tracking (AI extraction)
  sourceDocumentId              String?   // Which document this requirement was extracted from
  sourcePageNumber              Int?      // Which page (if known)
  extractionMethod              String    @default("AI")  // AI, MANUAL, HYBRID
  extractionConfidence          Float     @default(0.8)  // 0-1 scale
  isManuallyVerified            Boolean   @default(false)
  manualOverrideReason          String?   // Why the requirement was manually overridden

  // Proposal coverage tracking (future use)
  proposalSectionId             String?   // Linked proposal section
  coverageStatus                String    @default("UNCOVERED")  // UNCOVERED, PARTIAL, COVERED
  coverageScore                 Float     @default(0)  // 0-1: how well addressed

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matrix ComplianceMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  sourceDocument OpportunityDocument? @relation("SourceDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([matrixId])
  @@index([sourceDocumentId])
  @@map("matrix_requirements")
}

//////////////////////////////////////////////////////////////
