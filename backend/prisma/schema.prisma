//////////////////////////////////////////////////////////////
// DELIVERABLE COMMENTS — Threaded discussion on ClientDocument
//////////////////////////////////////////////////////////////

enum CommentAuthorType {
  CONSULTANT
  CLIENT
}

model DeliverableComment {
  id             String            @id @default(cuid())
  deliverableId  String
  authorType     CommentAuthorType
  authorId       String
  authorName     String
  body           String
  parentId       String?
  isResolved     Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  deliverable ClientDocument       @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  parent      DeliverableComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     DeliverableComment[] @relation("CommentReplies")

  @@index([deliverableId])
  @@index([parentId])
  @@map("deliverable_comments")
