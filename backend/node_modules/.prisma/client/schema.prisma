// =============================================================
// GovCon Advisory Intelligence Platform
// Prisma Schema - Multi-Tenant SaaS Data Model
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// TENANT LAYER
// =============================================================

model ConsultingFirm {
  id           String  @id @default(uuid())
  name         String
  contactEmail String  @unique
  isActive     Boolean @default(true)

  lastIngestedAt DateTime?

  flatLateFee    Float?
  penaltyPercent Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  clientCompanies    ClientCompany[]
  opportunities      Opportunity[]
  financialPenalties FinancialPenalty[]
  ingestionJobs      IngestionJob[]

  @@map("consulting_firms")
}

model User {
  id               String   @id @default(uuid())
  consultingFirmId String
  email            String   @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             UserRole @default(CONSULTANT)
  isActive         Boolean  @default(true)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  consultingFirm    ConsultingFirm     @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submissionRecords SubmissionRecord[]

  @@index([consultingFirmId])
  @@map("users")
}

enum UserRole {
  ADMIN
  CONSULTANT
}

// =============================================================
// CLIENT LAYER
// =============================================================

model ClientCompany {
  id               String  @id @default(uuid())
  consultingFirmId String
  name             String
  cage             String?
  uei              String?

  naicsCodes        String[]
  preferredPscCodes String[]

  sdvosb        Boolean @default(false)
  wosb          Boolean @default(false)
  hubzone       Boolean @default(false)
  smallBusiness Boolean @default(true)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultingFirm     ConsultingFirm     @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submissionRecords  SubmissionRecord[]
  performanceStats   PerformanceStats?
  financialPenalties FinancialPenalty[]
  bidDecisions       BidDecision[]

  @@index([consultingFirmId])
  @@map("client_companies")
}

// =============================================================
// PRODUCT SERVICE CODES (PSC)
// =============================================================

model ProductServiceCode {
  id          String  @id @default(uuid())
  code        String  @unique
  description String
  category    String?

  opportunities OpportunityPSC[]

  @@index([code])
  @@map("product_service_codes")
}

model OpportunityPSC {
  opportunityId String
  pscId         String

  opportunity Opportunity        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  psc         ProductServiceCode @relation(fields: [pscId], references: [id], onDelete: Cascade)

  @@id([opportunityId, pscId])
  @@map("opportunity_psc")
}

// =============================================================
// OPPORTUNITY LAYER
// =============================================================

model Opportunity {
  id               String @id @default(uuid())
  consultingFirmId String

  samNoticeId String?
  title       String
  agency      String
  subagency   String?
  office      String?

  naicsCode        String
  naicsDescription String?

  setAsideType   SetAsideType   @default(NONE)
  marketCategory MarketCategory @default(SUPPLIES)

  estimatedValue    Float?
  estimatedValueMin Float?
  estimatedValueMax Float?

  postedDate       DateTime?
  responseDeadline DateTime
  archiveDate      DateTime?

  placeOfPerformance String?

  sourceUrl   String?
  description String? @db.Text
  attachments Json?

  // Scoring outputs
  probabilityScore Float?  @default(0)
  expectedValue    Float?  @default(0)
  isScored         Boolean @default(false)

  // Enrichment intelligence fields
  isEnriched              Boolean @default(false)
  historicalWinner        String?
  historicalAvgAward      Float?
  historicalAwardCount    Int?
  competitionCount        Int?
  incumbentProbability    Float?
  agencySmallBizRate      Float?
  agencySdvosbRate        Float?
  recompeteFlag           Boolean @default(false)
  documentIntelScore      Float?
  scopeAlignmentScore     Float?
  technicalComplexScore   Float?
  incumbentSignalDetected Boolean @default(false)

  status OpportunityStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultingFirm    ConsultingFirm        @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  submissionRecords SubmissionRecord[]
  bidDecisions      BidDecision[]
  pscCodes          OpportunityPSC[]
  amendments        Amendment[]
  awardHistory      AwardHistory[]
  documents         OpportunityDocument[]

  @@unique([consultingFirmId, samNoticeId])
  @@index([consultingFirmId])
  @@index([naicsCode])
  @@index([agency])
  @@index([responseDeadline])
  @@index([probabilityScore])
  @@map("opportunities")
}

enum SetAsideType {
  NONE
  SMALL_BUSINESS
  SDVOSB
  WOSB
  HUBZONE
  SBA_8A
  TOTAL_SMALL_BUSINESS
}

enum MarketCategory {
  SERVICES
  SUPPLIES
  CONSTRUCTION
  IT
  RESEARCH
  MEDICAL
  LOGISTICS
  OTHER
}

enum OpportunityStatus {
  ACTIVE
  AWARDED
  CANCELLED
  ARCHIVED
}

// =============================================================
// AMENDMENTS
// =============================================================

model Amendment {
  id            String @id
  opportunityId String

  amendmentNumber String?
  title           String?
  description     String?   @db.Text
  postedDate      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@map("amendments")
}

// =============================================================
// AWARD HISTORY (USAspending enrichment)
// =============================================================

model AwardHistory {
  id            String @id @default(cuid())
  opportunityId String

  awardingAgency    String
  recipientName     String
  recipientUei      String?
  awardAmount       Float
  awardDate         DateTime
  baseAndAllOptions Float?
  naics             String?
  psc               String?
  awardType         String?
  contractNumber    String?

  createdAt DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([recipientName])
  @@index([naics])
  @@map("award_history")
}

// =============================================================
// OPPORTUNITY DOCUMENTS (Amendment uploads)
// =============================================================

model OpportunityDocument {
  id            String @id @default(cuid())
  opportunityId String

  fileName   String
  fileType   String
  fileSize   Int
  storageKey String // local path or S3 key
  uploadedAt DateTime @default(now())

  // Claude analysis results
  analysisStatus   DocumentAnalysisStatus @default(PENDING)
  analysisError    String?
  scopeKeywords    String[]
  complexityScore  Float?
  alignmentScore   Float?
  incumbentSignals String[]
  rawAnalysis      Json?
  analyzedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@map("opportunity_documents")
}

enum DocumentAnalysisStatus {
  PENDING
  RUNNING
  COMPLETE
  FAILED
}

// =============================================================
// INGESTION JOB TRACKING
// =============================================================

model IngestionJob {
  id               String    @id @default(cuid())
  consultingFirmId String
  type             JobType
  status           JobStatus @default(PENDING)

  // Result metadata
  opportunitiesFound Int?
  opportunitiesNew   Int?
  enrichedCount      Int?
  scoringJobsQueued  Int?
  errors             Int?
  errorDetail        String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  consultingFirm ConsultingFirm @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)

  @@index([consultingFirmId])
  @@index([status])
  @@map("ingestion_jobs")
}

enum JobType {
  INGEST
  ENRICH
  ANALYZE_DOCUMENT
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETE
  FAILED
}

// =============================================================
// SUBMISSION TRACKING
// =============================================================

model SubmissionRecord {
  id               String @id @default(uuid())
  consultingFirmId String
  clientCompanyId  String
  opportunityId    String
  submittedById    String

  submittedAt   DateTime
  wasOnTime     Boolean
  penaltyAmount Float    @default(0)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientCompany    ClientCompany     @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  opportunity      Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  submittedBy      User              @relation(fields: [submittedById], references: [id])
  financialPenalty FinancialPenalty?

  @@index([clientCompanyId])
  @@index([opportunityId])
  @@index([consultingFirmId])
  @@map("submission_records")
}

// =============================================================
// FINANCIAL PENALTIES
// =============================================================

model FinancialPenalty {
  id                 String @id @default(uuid())
  consultingFirmId   String
  clientCompanyId    String
  submissionRecordId String @unique

  penaltyType      PenaltyType
  amount           Float
  calculationBasis String
  isPaid           Boolean     @default(false)
  paidAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultingFirm   ConsultingFirm   @relation(fields: [consultingFirmId], references: [id], onDelete: Cascade)
  clientCompany    ClientCompany    @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  submissionRecord SubmissionRecord @relation(fields: [submissionRecordId], references: [id])

  @@index([consultingFirmId])
  @@index([clientCompanyId])
  @@map("financial_penalties")
}

enum PenaltyType {
  FLAT_FEE
  PERCENTAGE
}

// =============================================================
// PERFORMANCE STATISTICS
// =============================================================

model PerformanceStats {
  id              String @id @default(uuid())
  clientCompanyId String @unique

  totalOpportunities Int   @default(0)
  totalSubmissions   Int   @default(0)
  submissionsOnTime  Int   @default(0)
  submissionsLate    Int   @default(0)
  completionRate     Float @default(0)
  totalPenalties     Float @default(0)

  lastCalculatedAt DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@map("performance_stats")
}

// =============================================================
// DECISION INTELLIGENCE ENGINE
// =============================================================

model BidDecision {
  id              String @id @default(cuid())
  opportunityId   String
  clientCompanyId String

  winProbability       Float
  expectedRevenue      Float
  proposalCostEstimate Float
  expectedValue        Float
  netExpectedValue     Float
  roiRatio             Float

  complianceStatus ComplianceStatus
  riskScore        Int
  recommendation   Recommendation
  explanationJson  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunity   Opportunity   @relation(fields: [opportunityId], references: [id])
  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id])

  @@unique([opportunityId, clientCompanyId])
  @@map("bid_decisions")
}

enum ComplianceStatus {
  PASS
  CONDITIONAL
  FAIL
}

enum Recommendation {
  BID_PRIME
  BID_SUB
  NO_BID
}
