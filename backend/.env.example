NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://govcon_user:govcon_pass@localhost:5432/govcon_platform
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=8h

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
MAX_UPLOAD_MB=25

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

SAM_API_KEY=
SAM_BASE_URL=https://api.sam.gov/opportunities/v2
USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Platform default AI provider (claude, openai, localai, deepseek, insight_engine)
# This is used when a firm hasn't configured their own provider.
DEFAULT_LLM_PROVIDER=openai

# ── Google Cloud / BigQuery ────────────────────────────────────
# Development: run "gcloud auth application-default login" (no key file needed)
# Docker/CI:   point to a service account JSON key file
GCP_PROJECT_ID=gov-con-491005
BQ_DATASET=govcon_analytics
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Email (Resend) ─────────────────────────────────────────────
# When RESEND_API_KEY is unset the mailer logs the email payload
# instead of sending — useful for local dev. In production set both.
# Domain authentication on mrgovcon.co (DKIM + SPF) is required for
# Gmail/Outlook deliverability — add the records Resend issues at
# Domains → Add domain. Docs: https://resend.com/docs/dashboard/domains/introduction
RESEND_API_KEY=
EMAIL_FROM=noreply@mrgovcon.co
EMAIL_FROM_NAME=Mr GovCon

# Public URL used in verification + password-reset email links
PUBLIC_APP_URL=https://mrgovcon.co

# ── Beta program ───────────────────────────────────────────────
# Maximum number of beta firm slots. Beta-status endpoint reports
# slotsRemaining = MAX_BETA_SLOTS - count(consultingFirms).
MAX_BETA_SLOTS=15
